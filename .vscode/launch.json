{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "g++ - 生成和调试活动文件", // 配置名称
            "type": "cppdbg",
            "request": "launch",
            // 要调试的程序路径：必须和 tasks.json 里 -o 参数输出的路径完全一致！
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "args": [],                          // 命令行参数，有需要可以在这里填
            "stopAtEntry": false,                // 是否在 main 函数入口处暂停
            "cwd": "${fileDirname}",              // 调试时的工作目录
            "environment": [],
            "externalConsole": false,             // false 表示在 VS Code 内置终端显示
            "MIMode": "gdb",
            // Windows 下必须指定 gdb.exe 的绝对路径！
            "miDebuggerPath": "E:\\mingw64\\x86_64-15.2.0-release-posix-seh-ucrt-rt_v13-rev1\\mingw64\\bin\\gdb.exe", // ⚠️ 请务必修改成你自己的路径！
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "C/C++: gcc.exe 生成活动文件" // 调试前执行的任务，必须和 tasks.json 里的 label 一致！
        }
    ]
}